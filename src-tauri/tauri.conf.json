{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Teebot Flow",
  "version": "0.0.5",
  "identifier": "com.teebot.teebot-flow",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Teebot Flow",
        "width": 960,
        "height": 680,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": ["tbf"],
        "name": "Teebot Flow Backup",
        "description": "Backup file for Teebot Flow workspace",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}